#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd -- "$script_dir/.." && pwd)"
usage_tool="${CODEX_USAGE_TOOL:-}"

if [[ -z "$usage_tool" ]]; then
  for candidate in \
    "$script_dir/codex-usage" \
    "$repo_root/tools/codex-usage"
  do
    if [[ -x "$candidate" ]]; then
      usage_tool="$candidate"
      break
    fi
  done
fi

if [[ -z "$usage_tool" ]]; then
  echo "could not locate codex-usage relative to $0" >&2
  echo "set CODEX_USAGE_TOOL to the wrapper path if the bundle was copied into a different layout" >&2
  exit 1
fi

command="snapshot"
if [[ $# -gt 0 ]]; then
  case "$1" in
    mark|smoke-test|snapshot|window)
      command="$1"
      shift
      ;;
  esac
fi

default_root="$PWD"
if git_root="$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null)"; then
  default_root="$git_root"
fi

project_id="$(basename "$default_root")"
artifact_root="${CODEX_OUT:-$default_root/_codex_out/usage-tracker}"
ledger="$artifact_root/${project_id}-ledger.jsonl"
cutoff_file="$artifact_root/${project_id}-cutoff-ms"
cwd_prefix="$default_root"
sqlite_path="${CODEX_USAGE_SQLITE:-${CODEX_HOME:-$HOME/.codex}/state_5.sqlite}"
cutoff_mode="created"
cutoff_ms=""
include_overhead=1
output_format="json"
report_ledger="$ledger"
scoped_ledger=""

usage() {
  cat <<'EOF'
Usage:
  codex-usage-checkpoint [snapshot|window|mark|smoke-test] [options]

Commands:
  snapshot   Ingest current repo-scoped usage and emit a compact report. Default.
  window     Use a saved or explicit cutoff to isolate recent work. `created` means new threads after the cutoff; `updated` means post-cutoff activity in threads touched after the cutoff.
  mark       Record the current millisecond timestamp for a later `window` run.
  smoke-test Validate wrapper resolution and probe local telemetry without writing a ledger.

Options:
  --project-id ID         Project id stored in the ledger.
  --ledger PATH           Ledger JSONL path.
  --sqlite PATH           Path to Codex state_5.sqlite.
  --cwd-prefix PATH       Limit imports to threads under this cwd prefix.
  --cutoff-file PATH      File used by `mark` and `window`.
  --cutoff-ms MS          Explicit cutoff instead of reading the cutoff file.
  --cutoff-mode MODE      `created` or `updated`. `created` means new threads after the cutoff; `updated` means post-cutoff activity in updated threads. Default: created.
  --format FORMAT         `json` or `text`. Default: json.
  --no-overhead           Omit the overhead report from output.
  -h, --help              Show this help text.

Examples:
  ./tools/codex-usage-checkpoint mark
  ./tools/codex-usage-checkpoint window
  ./tools/codex-usage-checkpoint smoke-test
  ./tools/codex-usage-checkpoint snapshot --format text
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --project-id)
      project_id="${2:?missing value for --project-id}"
      shift 2
      ;;
    --ledger)
      ledger="${2:?missing value for --ledger}"
      shift 2
      ;;
    --sqlite)
      sqlite_path="${2:?missing value for --sqlite}"
      shift 2
      ;;
    --cwd-prefix)
      cwd_prefix="${2:?missing value for --cwd-prefix}"
      shift 2
      ;;
    --cutoff-file)
      cutoff_file="${2:?missing value for --cutoff-file}"
      shift 2
      ;;
    --cutoff-ms)
      cutoff_ms="${2:?missing value for --cutoff-ms}"
      shift 2
      ;;
    --cutoff-mode)
      cutoff_mode="${2:?missing value for --cutoff-mode}"
      shift 2
      ;;
    --format)
      output_format="${2:?missing value for --format}"
      shift 2
      ;;
    --no-overhead)
      include_overhead=0
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

case "$cutoff_mode" in
  created|updated) ;;
  *)
    echo "--cutoff-mode must be 'created' or 'updated'" >&2
    exit 2
    ;;
esac

report_ledger="$ledger"

case "$output_format" in
  json|text) ;;
  *)
    echo "--format must be 'json' or 'text'" >&2
    exit 2
    ;;
esac

mkdir -p "$(dirname -- "$ledger")" "$(dirname -- "$cutoff_file")"

if [[ "$command" == "mark" ]]; then
  now_ms="$(date +%s%3N)"
  printf '%s\n' "$now_ms" > "$cutoff_file"
  if [[ "$output_format" == "json" ]]; then
    python - <<'PY' "$project_id" "$cutoff_file" "$now_ms"
import json, sys
print(json.dumps({
    "command": "mark",
    "project_id": sys.argv[1],
    "cutoff_file": sys.argv[2],
    "cutoff_ms": int(sys.argv[3]),
}, indent=2, sort_keys=True))
PY
  else
    printf 'command=mark project_id=%s cutoff_file=%s cutoff_ms=%s\n' "$project_id" "$cutoff_file" "$now_ms"
  fi
  exit 0
fi

if [[ "$command" == "smoke-test" ]]; then
  "$usage_tool" --help >/dev/null
  probe_status="not_run"
  probe_json="null"
  if [[ -f "$sqlite_path" ]]; then
    probe_json="$("$usage_tool" probe-sources --project-id "$project_id" --cwd-prefix "$cwd_prefix" --max-results 5 --format json)"
    probe_status="ok"
  fi
  if [[ "$output_format" == "json" ]]; then
    python - <<'PY' "$usage_tool" "$sqlite_path" "$cwd_prefix" "$probe_status" "$probe_json"
import json, os, sys

usage_tool, sqlite_path, cwd_prefix, probe_status, probe_json = sys.argv[1:]
result = {
    "command": "smoke-test",
    "usage_tool": usage_tool,
    "sqlite": sqlite_path,
    "sqlite_exists": os.path.isfile(sqlite_path),
    "cwd_prefix": cwd_prefix,
    "tracker_cli_ok": True,
    "probe_status": probe_status,
}
if probe_json != "null":
    sources = json.loads(probe_json)
    result["probe"] = {
        "source_count": len(sources),
        "importable_count": sum(1 for item in sources if item.get("importable")),
        "sources": sources,
    }
print(json.dumps(result, indent=2, sort_keys=True))
PY
  else
    printf 'command=smoke-test usage_tool=%s sqlite=%s sqlite_exists=%s cwd_prefix=%s tracker_cli_ok=true probe_status=%s\n' \
      "$usage_tool" "$sqlite_path" "$([[ -f "$sqlite_path" ]] && printf true || printf false)" "$cwd_prefix" "$probe_status"
    if [[ "$probe_json" != "null" ]]; then
      printf '\n[probe]\n%s\n' "$probe_json"
    fi
  fi
  exit 0
fi

if [[ "$command" == "window" && -z "$cutoff_ms" ]]; then
  if [[ ! -f "$cutoff_file" ]]; then
    echo "cutoff file not found: $cutoff_file" >&2
    echo "Run 'codex-usage-checkpoint mark' first or pass --cutoff-ms." >&2
    exit 1
  fi
  cutoff_ms="$(tr -d '[:space:]' < "$cutoff_file")"
fi

common_ingest_args=(
  ingest-state-sqlite
  --sqlite "$sqlite_path"
  --project-id "$project_id"
  --cwd-prefix "$cwd_prefix"
)

if [[ -n "$cutoff_ms" ]]; then
  if [[ "$cutoff_mode" == "created" ]]; then
    common_ingest_args+=(--min-created-at-ms "$cutoff_ms")
  else
    common_ingest_args+=(--min-updated-at-ms "$cutoff_ms")
  fi
fi

project_ingest_json="null"
if [[ "$command" == "window" ]]; then
  ledger_dir="$(dirname -- "$ledger")"
  ledger_base="$(basename -- "$ledger")"
  ledger_stem="${ledger_base%.jsonl}"
  scoped_ledger="$ledger_dir/${ledger_stem}-window-${cutoff_mode}-${cutoff_ms}.jsonl"
  report_ledger="$scoped_ledger"
  : > "$report_ledger"
  project_ingest_json="$("$usage_tool" "${common_ingest_args[@]}" --ledger "$ledger")"
fi

ingest_json="$("$usage_tool" "${common_ingest_args[@]}" --ledger "$report_ledger")"
report_json="$("$usage_tool" efficiency-report --ledger "$report_ledger" --project-id "$project_id" --format json)"

overhead_json="null"
if [[ "$include_overhead" -eq 1 ]]; then
  overhead_json="$("$usage_tool" overhead-report --ledger "$report_ledger" --project-id "$project_id" --format json)"
fi

if [[ "$output_format" == "json" ]]; then
  python - <<'PY' "$command" "$project_id" "$ledger" "$report_ledger" "$sqlite_path" "$cwd_prefix" "$cutoff_mode" "${cutoff_ms:-}" "$project_ingest_json" "$ingest_json" "$report_json" "$overhead_json"
import json, sys

command, project_id, ledger, report_ledger, sqlite_path, cwd_prefix, cutoff_mode, cutoff_ms, project_ingest_json, ingest_json, report_json, overhead_json = sys.argv[1:]

ingest = json.loads(ingest_json)
report = json.loads(report_json)

result = {
    "command": command,
    "project_id": project_id,
    "ledger": ledger,
    "report_ledger": report_ledger,
    "sqlite": sqlite_path,
    "cwd_prefix": cwd_prefix,
    "filter": None if not cutoff_ms else {
        "mode": cutoff_mode,
        "cutoff_ms": int(cutoff_ms),
    },
    "ingest": ingest,
    "report": report,
}

if project_ingest_json != "null":
    result["project_ingest"] = json.loads(project_ingest_json)

if overhead_json != "null":
    result["overhead"] = json.loads(overhead_json)

if command == "window" and cutoff_mode == "created" and int(ingest.get("event_count") or 0) == 0:
    result["hint"] = (
        "created windows only include threads created after the cutoff; "
        "if work stayed on an existing thread, rerun with --cutoff-mode updated."
    )

print(json.dumps(result, indent=2, sort_keys=True))
PY
else
  printf 'command=%s project_id=%s ledger=%s report_ledger=%s sqlite=%s cwd_prefix=%s\n' "$command" "$project_id" "$ledger" "$report_ledger" "$sqlite_path" "$cwd_prefix"
  if [[ -n "$cutoff_ms" ]]; then
    printf 'filter mode=%s cutoff_ms=%s\n' "$cutoff_mode" "$cutoff_ms"
  fi
  if [[ "$command" == "window" && "$cutoff_mode" == "created" ]]; then
    created_event_count="$(python - <<'PY' "$ingest_json"
import json, sys
print(int((json.loads(sys.argv[1]).get("event_count") or 0)))
PY
)"
    if [[ "$created_event_count" -eq 0 ]]; then
      printf 'hint created windows only include threads created after the cutoff; if work stayed on an existing thread, rerun with --cutoff-mode updated.\n'
    fi
  fi
  if [[ "$project_ingest_json" != "null" ]]; then
    printf '\n[project-ingest]\n%s\n' "$project_ingest_json"
  fi
  printf '\n[ingest]\n%s\n' "$ingest_json"
  printf '\n[report]\n'
  "$usage_tool" efficiency-report --ledger "$report_ledger" --project-id "$project_id" --format text
  if [[ "$include_overhead" -eq 1 ]]; then
    printf '\n[overhead]\n%s\n' "$overhead_json"
  fi
fi
