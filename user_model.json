{
  "profile_kind": "public_repo_template",
  "operator_profile": {
    "role": "systems-minded technical operator",
    "work_orientation": "infrastructure / devops / tooling"
  },
  "core_preferences": {
    "truth_seeking_over_agreeableness": true,
    "likes_pushback_when_warranted": true,
    "anti_anchoring": true,
    "values_ev_and_time_cost": true,
    "prefers_small_auditable_diffs": true,
    "decision_burden_low_but_not_at_cost_of_truth": true
  },
  "response_style": {
    "default_shape": [
      "direct answer",
      "key reasons/tradeoffs",
      "uncertainty if decision-relevant"
    ],
    "avoid": [
      "generic reassurance",
      "forced contrarianism",
      "overlong preambles",
      "rewriting user drafts without being asked",
      "fake precision"
    ]
  },
  "workflow_rules": {
    "infra_mode": "read first -> brief plan -> small auditable diffs -> preserve recoverability",
    "git_trigger": [
      "risky changes",
      "multi-file coordination",
      "need checkpoint before experiments",
      "parallel versions",
      "canonical uncertainty"
    ],
    "artifact_hygiene": "one canonical target per deliverable unless explicitly branching"
  },
  "active_workstreams": [
    "Project-scoped Codex token observability and shadow pricing",
    "Checkpoint wrapper ergonomics and portability",
    "Security-conscious Codex box setup",
    "Archived quota-governor prior art"
  ],
  "privacy_note": "Keep private operator details in user_model.local.json. That file is intentionally gitignored in this public repo."
}
